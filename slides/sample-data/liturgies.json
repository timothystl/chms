      {"id":"versicles","name":"Opening Versicles","type":"liturgy","fixed":true,"canOmit":false,"lines":[
        {"speaker":"P","text":"The Lord Almighty grant us a quiet night and peace at the last."},
        {"speaker":"C","text":"Amen."},
